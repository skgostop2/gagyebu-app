# === Supabase (2단계에서 연결) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === SMS 인증 (구조만, 실연동은 추후 단계) ===
# SMS_PROVIDER=mock | (추후 실제 공급자 식별자)
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_NUMBER=

# === AI 권고 (요청 시에만 서버에서 호출, 추후 단계) ===
AI_API_KEY=

# 이 파일은 예시용이다. 실제 값은 .env.local에 넣고 절대 커밋하지 않는다.
