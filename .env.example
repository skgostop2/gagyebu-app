# === Supabase (2단계에서 연결) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === SMS 인증 (구조만, 실연동은 추후 단계) ===
# SMS_PROVIDER=mock | (추후 실제 공급자 식별자)
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_NUMBER=

# === AI 권고 (요청 시에만 서버에서 호출) — Anthropic(Claude), OpenAI(ChatGPT) 중 아무 키나 등록하면 자동 사용 ===
# 명시적으로 강제하고 싶으면 AI_PROVIDER=anthropic 또는 AI_PROVIDER=openai (비워두면 등록된 키로 자동판별)
AI_PROVIDER=
# Anthropic 사용 시 (AI_API_KEY도 하위호환으로 계속 지원됨)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-5-20250929
# OpenAI 사용 시
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 이 파일은 예시용이다. 실제 값은 .env.local에 넣고 절대 커밋하지 않는다.
